export const importVlmJsonData = async (payload: {
  sourceFiles: string[];
  commit?: boolean;
  assignees?: string[];
  assignCount?: number;
  keepUnassigned?: boolean;
  imagePathMappings?: Array<{ from: string; to: string }>;
}): Promise<VlmJsonImportResult> => {
