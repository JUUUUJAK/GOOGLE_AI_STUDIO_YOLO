# Gemini (기존)
# GEMINI_API_KEY=

# --- API 베이스 URL ---
# 기본(개발): 비워 두면 "지금 주소창 호스트" + 포트 3001 → 별도 YOLO_API_STUDIO 등.
# 이 저장소의 Vite 플러그인 SQLite /api 만 쓰려면(단일 프로세스):
#   VITE_DEV_API_SAME_ORIGIN=true
#
# 개발: 비워 두면 "지금 주소창 호스트" + 포트 3001 (예: 192.168.0.5:5174 접속 → API는 192.168.0.5:3001).
# 다른 PC에서 로그인 안 되면 127.0.0.1 때문이었을 수 있음 → 이 동작으로 해결.
# API 포트만 바꿀 때: VITE_API_PORT=3002
# UI/API를 다른 머신에 둘 때는 URL 고정:
# VITE_API_BASE_URL=http://192.168.0.10:3001
#
# 운영 빌드(npm run build): 반드시 설정 (브라우저가 접속할 공개 API URL)
# VITE_API_BASE_URL=https://api.example.com
#
# 디스크 트리: GET /api/datasets/fs-children 은 항상 위 API_BASE_URL 로만 호출됩니다.
# datasets 폴더는 YOLO_API_STUDIO(또는 AID-Storage) 쪽에 두고, 해당 서버에 라우트를 구현하세요.
# 스펙: docs/api-datasets-fs-children.md

# --- 선택: 작업 목록 초기 동기화(로그인 직후 API 부하 완화) ---
# 로그인 직후 즉시 가져올 /api/datasets 페이지 배치 수(기본 2). 나머지는 백그라운드로 이어서 로드.
# VITE_TASK_INITIAL_SYNC_BATCHES=2
# 백그라운드 배치 간 대기(ms, 기본 120)
# VITE_TASK_BACKGROUND_DRAIN_GAP_MS=120
